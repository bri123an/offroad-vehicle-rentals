@page "/maintenance"
@using OffroadVehicleRentals.Shared.Models
@rendermode InteractiveServer

<PageTitle>Maintenance & Repairs</PageTitle>

<h1>Maintenance & Repair Tracking</h1>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a class="nav-link @(activeTab == "maintenance" ? "active" : "")" @onclick='() => SetActiveTab("maintenance")' style="cursor: pointer;">
            Maintenance Records
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "repairs" ? "active" : "")" @onclick='() => SetActiveTab("repairs")' style="cursor: pointer;">
            Repair Records
        </a>
    </li>
</ul>

<div class="mb-3">
    @if (activeTab == "maintenance")
    {
        <button class="btn btn-primary" @onclick="ShowAddMaintenanceForm">
            <i class="bi bi-plus-circle"></i> Add Maintenance Record
        </button>
        @if (maintenanceRecords != null && maintenanceRecords.Any())
        {
            <button class="btn btn-success ms-2" @onclick="ExportMaintenanceToExcel" disabled="@isExporting">
                @if (isExporting)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                }
                <i class="bi bi-file-earmark-excel"></i> Export to Excel
            </button>
        }
    }
    else
    {
        <button class="btn btn-primary" @onclick="ShowAddRepairForm">
            <i class="bi bi-plus-circle"></i> Add Repair Record
        </button>
        @if (repairRecords != null && repairRecords.Any())
        {
            <button class="btn btn-success ms-2" @onclick="ExportRepairsToExcel" disabled="@isExporting">
                @if (isExporting)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                }
                <i class="bi bi-file-earmark-excel"></i> Export to Excel
            </button>
        }
    }
</div>

@if (activeTab == "maintenance")
{
    @if (isLoadingMaintenance)
    {
        <p><em>Loading maintenance records...</em></p>
    }
    else if (maintenanceRecords == null || !maintenanceRecords.Any())
    {
        <p><em>No maintenance records found.</em></p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Vehicle</th>
                        <th>Type</th>
                        <th>Description</th>
                        <th>Hours</th>
                        <th>Mileage</th>
                        <th>Cost</th>
                        <th>Performed By</th>
                    </tr>
                    <tr class="table-light">
                        <td></td>
                        <td><input type="text" class="form-control form-control-sm" placeholder="Filter..." @bind="filterMaintVehicle" @bind:event="oninput" /></td>
                        <td><input type="text" class="form-control form-control-sm" placeholder="Filter..." @bind="filterMaintType" @bind:event="oninput" /></td>
                        <td><input type="text" class="form-control form-control-sm" placeholder="Filter..." @bind="filterMaintDescription" @bind:event="oninput" /></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td><input type="text" class="form-control form-control-sm" placeholder="Filter..." @bind="filterMaintPerformedBy" @bind:event="oninput" /></td>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in FilteredMaintenanceRecords)
                    {
                        <tr>
                            <td>@record.MaintenanceDate.ToLocalTime().ToString("d")</td>
                            <td>@record.Vehicle?.VehicleNumber</td>
                            <td>@record.MaintenanceType</td>
                            <td>@record.Description</td>
                            <td>@record.HoursAtMaintenance.ToString("N2")</td>
                            <td>@record.MileageAtMaintenance.ToString("N2")</td>
                            <td>@(record.Cost.HasValue ? record.Cost.Value.ToString("C") : "-")</td>
                            <td>@record.PerformedBy</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
else
{
    @if (isLoadingRepairs)
    {
        <p><em>Loading repair records...</em></p>
    }
    else if (repairRecords == null || !repairRecords.Any())
    {
        <p><em>No repair records found.</em></p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Vehicle</th>
                        <th>Issue</th>
                        <th>Repair</th>
                        <th>Cost</th>
                        <th>Warranty</th>
                        <th>Performed By</th>
                    </tr>
                    <tr class="table-light">
                        <td></td>
                        <td><input type="text" class="form-control form-control-sm" placeholder="Filter..." @bind="filterRepairVehicle" @bind:event="oninput" /></td>
                        <td><input type="text" class="form-control form-control-sm" placeholder="Filter..." @bind="filterRepairIssue" @bind:event="oninput" /></td>
                        <td><input type="text" class="form-control form-control-sm" placeholder="Filter..." @bind="filterRepairDescription" @bind:event="oninput" /></td>
                        <td></td>
                        <td>
                            <select class="form-select form-select-sm" @bind="filterRepairWarranty">
                                <option value="">All</option>
                                <option value="Yes">Yes</option>
                                <option value="No">No</option>
                            </select>
                        </td>
                        <td><input type="text" class="form-control form-control-sm" placeholder="Filter..." @bind="filterRepairPerformedBy" @bind:event="oninput" /></td>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in FilteredRepairRecords)
                    {
                        <tr>
                            <td>@record.RepairDate.ToLocalTime().ToString("d")</td>
                            <td>@record.Vehicle?.VehicleNumber</td>
                            <td>@record.IssueDescription</td>
                            <td>@record.RepairDescription</td>
                            <td>@(record.Cost.HasValue ? record.Cost.Value.ToString("C") : "-")</td>
                            <td>
                                @if (record.IsWarrantyClaim)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td>@record.PerformedBy</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (showMaintenanceForm)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Maintenance Record</h5>
                    <button type="button" class="btn-close" @onclick="CloseMaintenanceForm"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editingMaintenance" OnValidSubmit="SaveMaintenance">
                        <div class="mb-3">
                            <label class="form-label">Vehicle</label>
                            <InputSelect @bind-Value="editingMaintenance!.VehicleId" class="form-select">
                                <option value="0">-- Select Vehicle --</option>
                                @if (vehicles != null)
                                {
                                    @foreach (var vehicle in vehicles)
                                    {
                                        <option value="@vehicle.Id">@vehicle.VehicleNumber - @vehicle.Make @vehicle.Model</option>
                                    }
                                }
                            </InputSelect>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Maintenance Date</label>
                                <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="editingMaintenance!.MaintenanceDate" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Maintenance Type</label>
                                <InputText @bind-Value="editingMaintenance!.MaintenanceType" class="form-control" placeholder="e.g., Oil Change, Air Filter" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea @bind-Value="editingMaintenance!.Description" class="form-control" rows="3" />
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Hours at Maintenance</label>
                                <InputNumber @bind-Value="editingMaintenance!.HoursAtMaintenance" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Mileage at Maintenance</label>
                                <InputNumber @bind-Value="editingMaintenance!.MileageAtMaintenance" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Cost</label>
                                <InputNumber @bind-Value="editingMaintenance!.Cost" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Performed By</label>
                            <InputText @bind-Value="editingMaintenance!.PerformedBy" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <InputTextArea @bind-Value="editingMaintenance!.Notes" class="form-control" rows="2" />
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CloseMaintenanceForm">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (showRepairForm)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Repair Record</h5>
                    <button type="button" class="btn-close" @onclick="CloseRepairForm"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editingRepair" OnValidSubmit="SaveRepair">
                        <div class="mb-3">
                            <label class="form-label">Vehicle</label>
                            <InputSelect @bind-Value="editingRepair!.VehicleId" class="form-select">
                                <option value="0">-- Select Vehicle --</option>
                                @if (vehicles != null)
                                {
                                    @foreach (var vehicle in vehicles)
                                    {
                                        <option value="@vehicle.Id">@vehicle.VehicleNumber - @vehicle.Make @vehicle.Model</option>
                                    }
                                }
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Repair Date</label>
                            <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="editingRepair!.RepairDate" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Issue Description</label>
                            <InputTextArea @bind-Value="editingRepair!.IssueDescription" class="form-control" rows="3" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Repair Description</label>
                            <InputTextArea @bind-Value="editingRepair!.RepairDescription" class="form-control" rows="3" />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Cost</label>
                                <InputNumber @bind-Value="editingRepair!.Cost" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Performed By</label>
                                <InputText @bind-Value="editingRepair!.PerformedBy" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3 form-check">
                            <InputCheckbox @bind-Value="editingRepair!.IsWarrantyClaim" class="form-check-input" id="warrantyCheck" />
                            <label class="form-check-label" for="warrantyCheck">
                                Warranty Claim
                            </label>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <InputTextArea @bind-Value="editingRepair!.Notes" class="form-control" rows="2" />
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CloseRepairForm">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

