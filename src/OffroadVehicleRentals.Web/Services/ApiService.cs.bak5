    public async Task<List<ChecklistItem>> GetVehicleChecklistItemsAsync(int vehicleId)
    {
        var response = await _httpClient.GetAsync($"/vehicles/{vehicleId}/checklist-items");
        response.EnsureSuccessStatusCode();
