@page "/rentals"
@using OffroadVehicleRentals.Shared.Models
@rendermode InteractiveServer

<PageTitle>Rentals</PageTitle>

<h1>Rental Management</h1>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowAddRentalForm">
        <i class="bi bi-plus-circle"></i> Schedule New Rental
    </button>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a class="nav-link @(activeTab == "upcoming" ? "active" : "")" @onclick='() => SetActiveTab("upcoming")' style="cursor: pointer;">
            Upcoming Rentals
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "active" ? "active" : "")" @onclick='() => SetActiveTab("active")' style="cursor: pointer;">
            Active Rentals
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(activeTab == "all" ? "active" : "")" @onclick='() => SetActiveTab("all")' style="cursor: pointer;">
            All Rentals
        </a>
    </li>
</ul>

@if (isLoading)
{
    <p><em>Loading rentals...</em></p>
}
else if (displayedRentals == null || !displayedRentals.Any())
{
    <p><em>No rentals found.</em></p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Vehicle</th>
                    <th>Customer</th>
                    <th>Contact</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Pre-Check</th>
                    <th>Post-Check</th>
                    <th>Actions</th>
                </tr>
                <tr class="table-light">
                    <td><input type="text" class="form-control form-control-sm" placeholder="Filter..." @bind="filterRentalVehicle" @bind:event="oninput" /></td>
                    <td><input type="text" class="form-control form-control-sm" placeholder="Filter..." @bind="filterRentalCustomer" @bind:event="oninput" /></td>
                    <td><input type="text" class="form-control form-control-sm" placeholder="Filter..." @bind="filterRentalContact" @bind:event="oninput" /></td>
                    <td></td>
                    <td></td>
                    <td>
                        <select class="form-select form-select-sm" @bind="filterPreCheck">
                            <option value="">All</option>
                            <option value="Complete">Complete</option>
                            <option value="Pending">Pending</option>
                        </select>
                    </td>
                    <td>
                        <select class="form-select form-select-sm" @bind="filterPostCheck">
                            <option value="">All</option>
                            <option value="Complete">Complete</option>
                            <option value="Pending">Pending</option>
                        </select>
                    </td>
                    <td></td>
                </tr>
            </thead>
            <tbody>
                @foreach (var rental in FilteredRentals)
                {
                    <tr>
                        <td>@rental.Vehicle?.VehicleNumber</td>
                        <td>@rental.CustomerName</td>
                        <td>
                            @if (!string.IsNullOrEmpty(rental.CustomerPhone))
                            {
                                <div>@rental.CustomerPhone</div>
                            }
                            @if (!string.IsNullOrEmpty(rental.CustomerEmail))
                            {
                                <div><small>@rental.CustomerEmail</small></div>
                            }
                        </td>
                        <td>@rental.StartDate.ToLocalTime().ToString("g")</td>
                        <td>@rental.EndDate.ToLocalTime().ToString("g")</td>
                        <td>
                            <span class="badge bg-@(rental.PreRentalChecklistCompleted ? "success" : "warning")">
                                @(rental.PreRentalChecklistCompleted ? "Complete" : "Pending")
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-@(rental.PostRentalChecklistCompleted ? "success" : "secondary")">
                                @(rental.PostRentalChecklistCompleted ? "Complete" : "Pending")
                            </span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-info me-1" @onclick="() => ViewRental(rental.Id)">
                                <i class="bi bi-eye"></i>
                            </button>
                            <button class="btn btn-sm btn-warning me-1" @onclick="() => EditRental(rental)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteRental(rental.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (showForm)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingRental?.Id > 0 ? "Edit Rental" : "Schedule New Rental")</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editingRental" OnValidSubmit="SaveRental">
                        <div class="mb-3">
                            <label class="form-label">Vehicle</label>
                            <InputSelect @bind-Value="editingRental!.VehicleId" class="form-select">
                                <option value="0">-- Select Vehicle --</option>
                                @if (availableVehicles != null)
                                {
                                    @foreach (var vehicle in availableVehicles)
                                    {
                                        <option value="@vehicle.Id">@vehicle.VehicleNumber - @vehicle.Make @vehicle.Model</option>
                                    }
                                }
                            </InputSelect>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Customer Name</label>
                                <InputText @bind-Value="editingRental!.CustomerName" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Phone</label>
                                <InputText @bind-Value="editingRental!.CustomerPhone" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Email</label>
                                <InputText @bind-Value="editingRental!.CustomerEmail" class="form-control" type="email" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Start Date/Time</label>
                                <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="editingRental!.StartDate" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">End Date/Time</label>
                                <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="editingRental!.EndDate" class="form-control" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Start Hours</label>
                                <InputNumber @bind-Value="editingRental!.StartHours" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Start Mileage</label>
                                <InputNumber @bind-Value="editingRental!.StartMileage" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <InputTextArea @bind-Value="editingRental!.Notes" class="form-control" rows="3" />
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

