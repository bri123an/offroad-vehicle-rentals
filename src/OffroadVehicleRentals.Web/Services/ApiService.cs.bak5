    }

    public async Task<List<ChecklistItem>> CreateChecklistItemsFromTemplateAsync(int templateId, int? rentalId, int? vehicleId)
    {
        var request = new { TemplateId = templateId, RentalId = rentalId, VehicleId = vehicleId };
        var response = await _httpClient.PostAsJsonAsync(AddFunctionKey("/checklist-items/from-template"), request);
        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<List<ChecklistItem>>() ?? new List<ChecklistItem>();
    }

    public async Task<ChecklistItem> UpdateChecklistItemAsync(int id, ChecklistItem item)
    {
        var response = await _httpClient.PutAsJsonAsync($"/checklist-items/{id}", item);
        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<ChecklistItem>() ?? item;
    }
}
