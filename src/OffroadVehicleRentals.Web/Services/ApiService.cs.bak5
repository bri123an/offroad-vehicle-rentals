    }

    // Repair Methods
    public async Task<List<RepairRecord>> GetRepairRecordsAsync()
    {
        var response = await _httpClient.GetAsync(AddFunctionKey("/repairs"));
        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<List<RepairRecord>>() ?? new List<RepairRecord>();
    }

