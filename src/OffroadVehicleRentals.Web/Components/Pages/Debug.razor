@page "/debug"
@rendermode InteractiveServer

<PageTitle>Debug Info</PageTitle>

<h1>Debug Information</h1>

<h3>Configuration</h3>
<ul>
    <li><strong>ApimBaseUrl:</strong> @Configuration["ApimBaseUrl"]</li>
    <li><strong>FunctionAppKey:</strong> @(string.IsNullOrEmpty(Configuration["FunctionAppKey"]) ? "Not Set" : "****" + Configuration["FunctionAppKey"]?.Substring(Math.Max(0, Configuration["FunctionAppKey"].Length - 4)))</li>
</ul>

<h3>API Test</h3>
@if (isLoading)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">
        <strong>Error:</strong> @errorMessage
    </div>
}
else
{
    <div class="alert alert-success">
        <strong>Success!</strong> Retrieved @vehicleCount vehicles
    </div>
    @if (!string.IsNullOrEmpty(responseData))
    {
        <pre>@responseData</pre>
    }
}

<button class="btn btn-primary" @onclick="TestApi">Test API</button>

