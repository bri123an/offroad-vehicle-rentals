@page "/rentals/{Id:int}"
@using OffroadVehicleRentals.Shared.Models
@rendermode InteractiveServer

<PageTitle>Rental Details</PageTitle>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2">Loading rental details...</p>
    </div>
}
else if (rental == null)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i> Rental not found.
        <a href="/rentals" class="alert-link">Return to Rentals</a>
    </div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/rentals">Rentals</a></li>
            <li class="breadcrumb-item active">@rental.CustomerName</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Rental — @rental.CustomerName</h1>
        <div>
            <button class="btn btn-warning me-2" @onclick="EditRental">
                <i class="bi bi-pencil"></i> Edit
            </button>
            <a href="/rentals" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <div class="row mb-4">
        <!-- Customer Info -->
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">Customer Information</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@rental.CustomerName</dd>

                        <dt class="col-sm-4">Phone</dt>
                        <dd class="col-sm-8">@(rental.CustomerPhone ?? "—")</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@(rental.CustomerEmail ?? "—")</dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Rental Details -->
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">Rental Details</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Vehicle</dt>
                        <dd class="col-sm-7">
                            @if (rental.Vehicle != null)
                            {
                                <a href="/vehicles/@rental.VehicleId">@rental.Vehicle.VehicleNumber — @rental.Vehicle.Make @rental.Vehicle.Model</a>
                            }
                            else
                            {
                                <span>Vehicle #@rental.VehicleId</span>
                            }
                        </dd>

                        <dt class="col-sm-5">Start</dt>
                        <dd class="col-sm-7">@rental.StartDate.ToLocalTime().ToString("g")</dd>

                        <dt class="col-sm-5">End</dt>
                        <dd class="col-sm-7">@rental.EndDate.ToLocalTime().ToString("g")</dd>

                        <dt class="col-sm-5">Duration</dt>
                        <dd class="col-sm-7">@GetDurationText()</dd>

                        <dt class="col-sm-5">Status</dt>
                        <dd class="col-sm-7">
                            <span class="badge bg-@GetRentalStatusColor()">@GetRentalStatusText()</span>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Usage & Checklists -->
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">Usage & Checklists</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Start Hours</dt>
                        <dd class="col-sm-7">@rental.StartHours.ToString("N2")</dd>

                        <dt class="col-sm-5">End Hours</dt>
                        <dd class="col-sm-7">@(rental.EndHours?.ToString("N2") ?? "—")</dd>

                        <dt class="col-sm-5">Start Mileage</dt>
                        <dd class="col-sm-7">@rental.StartMileage.ToString("N2")</dd>

                        <dt class="col-sm-5">End Mileage</dt>
                        <dd class="col-sm-7">@(rental.EndMileage?.ToString("N2") ?? "—")</dd>

                        <dt class="col-sm-5">Pre-Check</dt>
                        <dd class="col-sm-7">
                            <span class="badge bg-@(rental.PreRentalChecklistCompleted ? "success" : "warning")">
                                @(rental.PreRentalChecklistCompleted ? "Complete" : "Pending")
                            </span>
                        </dd>

                        <dt class="col-sm-5">Post-Check</dt>
                        <dd class="col-sm-7">
                            <span class="badge bg-@(rental.PostRentalChecklistCompleted ? "success" : "secondary")">
                                @(rental.PostRentalChecklistCompleted ? "Complete" : "Pending")
                            </span>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(rental.Notes))
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Notes</h5>
            </div>
            <div class="card-body">
                <p class="mb-0">@rental.Notes</p>
            </div>
        </div>
    }

    <!-- Checklist Items -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Checklist Items</h5>
            @if (checklistItems != null)
            {
                <span class="badge bg-primary">@checklistItems.Count(i => i.IsCompleted) / @checklistItems.Count completed</span>
            }
        </div>
        <div class="card-body">
            @if (checklistItems != null && checklistItems.Any())
            {
                <div class="list-group">
                    @foreach (var item in checklistItems)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" checked="@item.IsCompleted"
                                           @onchange="() => ToggleChecklistItem(item)" />
                                    <label class="form-check-label @(item.IsCompleted ? "text-decoration-line-through text-muted" : "")">
                                        @item.ItemText
                                    </label>
                                </div>
                                @if (!string.IsNullOrEmpty(item.Notes))
                                {
                                    <small class="text-muted ms-4">@item.Notes</small>
                                }
                            </div>
                            <div>
                                @if (item.IsCompleted && item.CompletedDate.HasValue)
                                {
                                    <small class="text-muted">
                                        @item.CompletedBy — @item.CompletedDate.Value.ToLocalTime().ToString("g")
                                    </small>
                                }
                                <span class="badge bg-@(item.Type == ChecklistType.PreRental ? "success" : item.Type == ChecklistType.PostRental ? "warning" : "primary") ms-2">
                                    @item.Type
                                </span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No checklist items for this rental.</p>
            }
        </div>
    </div>
}

@if (showEditForm)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Rental</h5>
                    <button type="button" class="btn-close" @onclick="CloseEditForm"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editingRental" OnValidSubmit="SaveRental">
                        <div class="mb-3">
                            <label class="form-label">Vehicle</label>
                            <InputSelect @bind-Value="editingRental!.VehicleId" class="form-select">
                                <option value="0">-- Select Vehicle --</option>
                                @if (availableVehicles != null)
                                {
                                    @foreach (var v in availableVehicles)
                                    {
                                        <option value="@v.Id">@v.VehicleNumber - @v.Make @v.Model</option>
                                    }
                                }
                            </InputSelect>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Customer Name</label>
                                <InputText @bind-Value="editingRental!.CustomerName" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Phone</label>
                                <InputText @bind-Value="editingRental!.CustomerPhone" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Email</label>
                                <InputText @bind-Value="editingRental!.CustomerEmail" class="form-control" type="email" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Start Date/Time</label>
                                <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="editingRental!.StartDate" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">End Date/Time</label>
                                <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="editingRental!.EndDate" class="form-control" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Start Hours</label>
                                <InputNumber @bind-Value="editingRental!.StartHours" class="form-control" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">End Hours</label>
                                <InputNumber @bind-Value="editingRental!.EndHours" class="form-control" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Start Mileage</label>
                                <InputNumber @bind-Value="editingRental!.StartMileage" class="form-control" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">End Mileage</label>
                                <InputNumber @bind-Value="editingRental!.EndMileage" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <InputTextArea @bind-Value="editingRental!.Notes" class="form-control" rows="3" />
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CloseEditForm">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

