        return await response.Content.ReadFromJsonAsync<List<Rental>>() ?? new List<Rental>();
    }

    public async Task<Rental> CreateRentalAsync(Rental rental)
    {
        var response = await _httpClient.PostAsJsonAsync(AddFunctionKey("/rentals"), rental);
        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<Rental>() ?? rental;
    }

    public async Task<Rental> UpdateRentalAsync(int id, Rental rental)
    {
        var response = await _httpClient.PutAsJsonAsync($"/rentals/{id}", rental);
