    {
        var response = await _httpClient.GetAsync($"/vehicles/{vehicleId}/repairs");
        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<List<RepairRecord>>() ?? new List<RepairRecord>();
    }

    public async Task<RepairRecord> CreateRepairRecordAsync(RepairRecord record)
    {
        var response = await _httpClient.PostAsJsonAsync(AddFunctionKey("/repairs"), record);
        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<RepairRecord>() ?? record;
