    public async Task<MaintenanceRecord> CreateMaintenanceRecordAsync(MaintenanceRecord record)
    {
        var response = await _httpClient.PostAsJsonAsync(AddFunctionKey("/maintenance"), record);
        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<MaintenanceRecord>() ?? record;
    }

    public async Task<MaintenanceRecord> UpdateMaintenanceRecordAsync(int id, MaintenanceRecord record)
    {
        var response = await _httpClient.PutAsJsonAsync($"/maintenance/{id}", record);
        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<MaintenanceRecord>() ?? record;
    }

    public async Task DeleteMaintenanceRecordAsync(int id)
    {
        var response = await _httpClient.DeleteAsync($"/maintenance/{id}");
