@page "/vehicles/{Id:int}"
@using OffroadVehicleRentals.Shared.Models
@rendermode InteractiveServer

<PageTitle>Vehicle Details</PageTitle>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2">Loading vehicle details...</p>
    </div>
}
else if (vehicle == null)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i> Vehicle not found.
        <a href="/vehicles" class="alert-link">Return to Vehicles</a>
    </div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/vehicles">Vehicles</a></li>
            <li class="breadcrumb-item active">@vehicle.VehicleNumber</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            @vehicle.VehicleNumber
            <span class="badge bg-@GetStatusColor(vehicle.Status) fs-6">@vehicle.Status</span>
        </h1>
        <div>
            <button class="btn btn-warning me-2" @onclick="EditVehicle">
                <i class="bi bi-pencil"></i> Edit
            </button>
            <a href="/vehicles" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- Vehicle Info Cards -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">Vehicle Information</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Vehicle Number</dt>
                        <dd class="col-sm-7">@vehicle.VehicleNumber</dd>

                        <dt class="col-sm-5">Type</dt>
                        <dd class="col-sm-7">@vehicle.Type</dd>

                        <dt class="col-sm-5">Make</dt>
                        <dd class="col-sm-7">@vehicle.Make</dd>

                        <dt class="col-sm-5">Model</dt>
                        <dd class="col-sm-7">@vehicle.Model</dd>

                        <dt class="col-sm-5">Year</dt>
                        <dd class="col-sm-7">@vehicle.Year</dd>

                        <dt class="col-sm-5">Status</dt>
                        <dd class="col-sm-7">
                            <span class="badge bg-@GetStatusColor(vehicle.Status)">@vehicle.Status</span>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">Usage & Maintenance</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Current Hours</dt>
                        <dd class="col-sm-7">@vehicle.CurrentHours.ToString("N2")</dd>

                        <dt class="col-sm-5">Current Mileage</dt>
                        <dd class="col-sm-7">@vehicle.CurrentMileage.ToString("N2")</dd>

                        <dt class="col-sm-5">Last Maintenance</dt>
                        <dd class="col-sm-7">@(vehicle.LastMaintenanceDate?.ToLocalTime().ToString("d") ?? "N/A")</dd>

                        <dt class="col-sm-5">Next Maint. Hours</dt>
                        <dd class="col-sm-7">@(vehicle.NextMaintenanceHours?.ToString("N2") ?? "N/A")</dd>

                        <dt class="col-sm-5">Next Maint. Mileage</dt>
                        <dd class="col-sm-7">@(vehicle.NextMaintenanceMileage?.ToString("N2") ?? "N/A")</dd>

                        <dt class="col-sm-5">Added</dt>
                        <dd class="col-sm-7">@vehicle.CreatedDate.ToLocalTime().ToString("g")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(vehicle.Notes))
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Notes</h5>
            </div>
            <div class="card-body">
                <p class="mb-0">@vehicle.Notes</p>
            </div>
        </div>
    }

    <!-- Tabs for History -->
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <a class="nav-link @(activeTab == "rentals" ? "active" : "")" @onclick='() => activeTab = "rentals"' style="cursor: pointer;">
                <i class="bi bi-calendar-check"></i> Rental History
                @if (rentals != null)
                {
                    <span class="badge bg-primary ms-1">@rentals.Count</span>
                }
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(activeTab == "maintenance" ? "active" : "")" @onclick='() => activeTab = "maintenance"' style="cursor: pointer;">
                <i class="bi bi-wrench"></i> Maintenance
                @if (maintenanceRecords != null)
                {
                    <span class="badge bg-warning text-dark ms-1">@maintenanceRecords.Count</span>
                }
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(activeTab == "repairs" ? "active" : "")" @onclick='() => activeTab = "repairs"' style="cursor: pointer;">
                <i class="bi bi-tools"></i> Repairs
                @if (repairRecords != null)
                {
                    <span class="badge bg-danger ms-1">@repairRecords.Count</span>
                }
            </a>
        </li>
    </ul>

    @if (activeTab == "rentals")
    {
        @if (rentals != null && rentals.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Customer</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Start Hours</th>
                            <th>End Hours</th>
                            <th>Pre-Check</th>
                            <th>Post-Check</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rental in rentals.OrderByDescending(r => r.StartDate))
                        {
                            <tr>
                                <td>
                                    <a href="/rentals/@rental.Id">@rental.CustomerName</a>
                                </td>
                                <td>@rental.StartDate.ToLocalTime().ToString("g")</td>
                                <td>@rental.EndDate.ToLocalTime().ToString("g")</td>
                                <td>@rental.StartHours.ToString("N2")</td>
                                <td>@(rental.EndHours?.ToString("N2") ?? "—")</td>
                                <td>
                                    <span class="badge bg-@(rental.PreRentalChecklistCompleted ? "success" : "warning")">
                                        @(rental.PreRentalChecklistCompleted ? "Complete" : "Pending")
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-@(rental.PostRentalChecklistCompleted ? "success" : "secondary")">
                                        @(rental.PostRentalChecklistCompleted ? "Complete" : "Pending")
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No rental history for this vehicle.</p>
        }
    }

    @if (activeTab == "maintenance")
    {
        @if (maintenanceRecords != null && maintenanceRecords.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Hours</th>
                            <th>Mileage</th>
                            <th>Cost</th>
                            <th>Performed By</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in maintenanceRecords.OrderByDescending(r => r.MaintenanceDate))
                        {
                            <tr>
                                <td>@record.MaintenanceDate.ToLocalTime().ToString("d")</td>
                                <td>@record.MaintenanceType</td>
                                <td>@record.Description</td>
                                <td>@record.HoursAtMaintenance.ToString("N2")</td>
                                <td>@record.MileageAtMaintenance.ToString("N2")</td>
                                <td>@(record.Cost.HasValue ? record.Cost.Value.ToString("C") : "—")</td>
                                <td>@record.PerformedBy</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No maintenance records for this vehicle.</p>
        }
    }

    @if (activeTab == "repairs")
    {
        @if (repairRecords != null && repairRecords.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Issue</th>
                            <th>Repair</th>
                            <th>Cost</th>
                            <th>Warranty</th>
                            <th>Performed By</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in repairRecords.OrderByDescending(r => r.RepairDate))
                        {
                            <tr>
                                <td>@record.RepairDate.ToLocalTime().ToString("d")</td>
                                <td>@record.IssueDescription</td>
                                <td>@record.RepairDescription</td>
                                <td>@(record.Cost.HasValue ? record.Cost.Value.ToString("C") : "—")</td>
                                <td>
                                    @if (record.IsWarrantyClaim)
                                    {
                                        <span class="badge bg-success">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">No</span>
                                    }
                                </td>
                                <td>@record.PerformedBy</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No repair records for this vehicle.</p>
        }
    }
}

@if (showEditForm)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Vehicle</h5>
                    <button type="button" class="btn-close" @onclick="CloseEditForm"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editingVehicle" OnValidSubmit="SaveVehicle">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Vehicle Number</label>
                                <InputText @bind-Value="editingVehicle!.VehicleNumber" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Type</label>
                                <InputSelect @bind-Value="editingVehicle!.Type" class="form-select">
                                    <option value="@VehicleType.FourWheeler">4-Wheeler</option>
                                    <option value="@VehicleType.SideBySide">Side-by-Side</option>
                                </InputSelect>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Make</label>
                                <InputText @bind-Value="editingVehicle!.Make" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Model</label>
                                <InputText @bind-Value="editingVehicle!.Model" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Year</label>
                                <InputNumber @bind-Value="editingVehicle!.Year" class="form-control" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Status</label>
                                <InputSelect @bind-Value="editingVehicle!.Status" class="form-select">
                                    @foreach (var s in Enum.GetValues<VehicleStatus>())
                                    {
                                        <option value="@s">@s</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Current Hours</label>
                                <InputNumber @bind-Value="editingVehicle!.CurrentHours" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Current Mileage</label>
                                <InputNumber @bind-Value="editingVehicle!.CurrentMileage" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <InputTextArea @bind-Value="editingVehicle!.Notes" class="form-control" rows="3" />
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CloseEditForm">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

