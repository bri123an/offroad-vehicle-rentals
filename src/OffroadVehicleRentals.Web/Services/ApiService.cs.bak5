using OffroadVehicleRentals.Shared.Models;
using System.Text.Json;
using System.Text;

namespace OffroadVehicleRentals.Web.Services;

public class ApiService
{
    private readonly HttpClient _httpClient;
    private readonly IConfiguration _configuration;
    private readonly string _functionKey;

    public ApiService(HttpClient httpClient, IConfiguration configuration)
    {
        _httpClient = httpClient;
        _configuration = configuration;

        var apimBaseUrl = _configuration["ApimBaseUrl"];
        var subscriptionKey = _configuration["ApimSubscriptionKey"];
        _functionKey = _configuration["FunctionAppKey"] ?? _configuration["ApimSubscriptionKey"] ?? "";

        if (!string.IsNullOrEmpty(apimBaseUrl))
        {
            _httpClient.BaseAddress = new Uri(apimBaseUrl);
        }

        if (!string.IsNullOrEmpty(subscriptionKey) && subscriptionKey != "none")
        {
            _httpClient.DefaultRequestHeaders.Add("Ocp-Apim-Subscription-Key", subscriptionKey);
        }
    }

    private string AddFunctionKey(string url)
    {
        if (string.IsNullOrEmpty(_functionKey) || _functionKey == "none")
            return url;

        var separator = url.Contains('?') ? "&" : "?";
        return $"{url}{separator}code={_functionKey}";
    }

    // Vehicle Methods
    public async Task<List<Vehicle>> GetVehiclesAsync()
    {
        var response = await _httpClient.GetAsync(AddFunctionKey("/vehicles"));
        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<List<Vehicle>>() ?? new List<Vehicle>();
    }

    public async Task<Vehicle?> GetVehicleAsync(int id)
    {
        var response = await _httpClient.GetAsync(AddFunctionKey($"/vehicles/{id}"));
        if (response.IsSuccessStatusCode)
        {
            return await response.Content.ReadFromJsonAsync<Vehicle>();
        }
        return null;
    }

    public async Task<List<Vehicle>> GetAvailableVehiclesAsync()
    {
        var response = await _httpClient.GetAsync(AddFunctionKey("/vehicles/available"));
        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<List<Vehicle>>() ?? new List<Vehicle>();
    }

    public async Task<Vehicle> CreateVehicleAsync(Vehicle vehicle)
    {
        var response = await _httpClient.PostAsJsonAsync(AddFunctionKey("/vehicles"), vehicle);
        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<Vehicle>() ?? vehicle;
    }

    public async Task<Vehicle> UpdateVehicleAsync(int id, Vehicle vehicle)
    {
        var response = await _httpClient.PutAsJsonAsync($"/vehicles/{id}", vehicle);
        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<Vehicle>() ?? vehicle;
    }

    public async Task DeleteVehicleAsync(int id)
    {
        var response = await _httpClient.DeleteAsync($"/vehicles/{id}");
        response.EnsureSuccessStatusCode();
    }

    // Rental Methods
    public async Task<List<Rental>> GetRentalsAsync()
    {
        var response = await _httpClient.GetAsync(AddFunctionKey("/rentals"));
